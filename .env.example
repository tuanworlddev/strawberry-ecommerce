# Shared project settings
SPRING_PROFILES_ACTIVE=prod

# Database
POSTGRES_DB=strawberry_db
POSTGRES_USER=strawberry_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USERNAME=strawberry_mq
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Application ports
BACKEND_PORT=8080
FRONTEND_PORT=4200
PGADMIN_PORT=5050

# Security / uploads
JWT_SECRET=change_me_with_a_long_random_base64_or_hex_secret
JWT_EXPIRATION=86400000
CLOUDINARY_URL=

# Optional tools
PGADMIN_EMAIL=admin@strawberry.local
PGADMIN_PASSWORD=change_me_pgadmin_password

# Image names for release workflows
BACKEND_IMAGE=ghcr.io/your-org-or-user/strawberry-backend
FRONTEND_IMAGE=ghcr.io/your-org-or-user/strawberry-frontend
